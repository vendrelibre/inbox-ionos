# --- Config IONOS ---
# Copie ce fichier en ".env" (meme dossier) et remplis IMAP_PASSWORD.
# Le fichier .env reste sur ton PC : il n'est jamais partage, jamais envoye, jamais commite.

IMAP_HOST=imap.ionos.fr
IMAP_PORT=993
IMAP_USER=ton.adresse@ton-domaine.fr
IMAP_PASSWORD=colle-ici-le-mot-de-passe-de-ta-boite

# Nombre de mails recents a lire pour le test
FETCH_LIMIT=20
